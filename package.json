{
  "name": "moon-no-sleep",
  "version": "0.1.0",
  "description": "A quiet Astro magazine theme for essays, field notes, and long-form writing.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/prune-unused-assets.mjs",
    "preview": "astro preview",
    "format": "prettier --write .",
    "deploy": "gh-pages -d dist --dotfiles"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.4",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.4",
    "vite": "^8.1.2"
  }
}